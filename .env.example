# Mercado Libre
# El callback URI se calcula solo como {APP_URL}/api/ecommerce/ml/callback, no se configura aparte.
ML_CLIENT_ID=
ML_CLIENT_SECRET=

# Storage
UPLOAD_DIR=./uploads

# App
NODE_ENV=development
PORT=3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
