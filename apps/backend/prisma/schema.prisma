generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  CATALOG_MANAGER
  VENDEDOR
  DESPACHADOR
}

enum MarketplaceType {
  MERCADO_LIBRE
  SHOPIFY
  WOOCOMMERCE
  JUMPSELLER
  FALABELLA
  PARIS
  HITES
  RIPLEY
  WALMART
}

enum ListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  ERROR
}

enum SaleChannel {
  POS
  MERCADO_LIBRE
  SHOPIFY
  WOOCOMMERCE
  JUMPSELLER
  FALABELLA
  PARIS
  HITES
  RIPLEY
  WALMART
  MANUAL
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum MovementType {
  SALE
  RETURN
  ADJUSTMENT
  INITIAL
}

enum RouteStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum FulfillmentType {
  PICKUP
  DELIVERY
}

enum EmailType {
  ORDER_CONFIRMED
  ORDER_PREPARING
  ORDER_READY_PICKUP
  ORDER_OUT_FOR_DELIVERY
  ORDER_DELIVERED
  SALE_RECEIPT
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active          Boolean  @default(true)
  maxUsers        Int      @default(10)
  modules         Json?
  mlClientId      String?
  mlClientSecret  String?
  createdAt       DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  products           Product[]
  warehouses         Warehouse[]
  orders             Order[]
  dispatchRoutes     DispatchRoute[]
  connections        MarketplaceConnection[]
  sales              Sale[]
  billingConnections BillingConnection[]
  invoices           Invoice[]
  emailConfig        EmailConfig?
  emailTemplates     EmailTemplate[]

  @@map("companies")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  modules Json?

  auditLogs      AuditLog[]
  sales          Sale[]
  stockMovements StockMovement[]
  ordersCreated  Order[]          @relation("OrderCreatedBy")
  itemChecks     OrderItemCheck[] @relation("ItemCheckedBy")
  shipmentPhotos  ShipmentPhoto[]
  dispatchRoutes  DispatchRoute[] @relation("DispatcherRoutes")
  routesCreated   DispatchRoute[] @relation("RouteCreatedBy")

  @@map("users")
}

model MarketplaceConnection {
  id             String          @id @default(cuid())
  name           String
  marketplace    MarketplaceType
  mlClientId     String?
  mlClientSecret String?
  accessToken    String          @default("")
  refreshToken   String?
  expiresAt      DateTime?
  credentials    Json?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  listings Listing[]

  @@map("marketplace_connections")
}

model Warehouse {
  id          String    @id @default(cuid())
  name        String
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  products Product[]
  orders   Order[]

  @@map("warehouses")
}

model Product {
  id          String   @id @default(cuid())
  sku         String
  name        String
  description    String?  @db.Text
  mlDescription  String?  @db.Text
  mlAttributes   Json?
  price          Decimal  @db.Decimal(10, 2)
  cost           Decimal? @db.Decimal(10, 2)
  stock          Int      @default(0)
  category       String?
  mlCategoryId   String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  images          ProductImage[]
  listings        Listing[]
  saleItems       SaleItem[]
  stockMovements  StockMovement[]
  orderItemChecks OrderItemCheck[]

  @@unique([sku, companyId])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  filename  String
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Listing {
  id         String        @id @default(cuid())
  externalId String?
  status     ListingStatus @default(DRAFT)
  externalUrl String?
  syncedAt   DateTime?
  errorMsg   String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  productId    String
  product      Product               @relation(fields: [productId], references: [id])
  connectionId String
  connection   MarketplaceConnection @relation(fields: [connectionId], references: [id])

  @@unique([productId, connectionId])
  @@map("listings")
}

model Sale {
  id              String           @id @default(cuid())
  channel         SaleChannel      @default(POS)
  externalId      String?
  total           Decimal          @db.Decimal(10, 2)
  shippingCost    Decimal?         @db.Decimal(10, 2)
  marketplaceFee  Decimal?         @db.Decimal(10, 2)
  taxes           Decimal?         @db.Decimal(10, 2)
  discount        Decimal?         @db.Decimal(10, 2)
  netAmount       Decimal?         @db.Decimal(10, 2)
  paymentMethod   PaymentMethod?
  notes           String?
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  fulfillmentType FulfillmentType?
  shippingMethod  String?
  address         String?
  commune         String?
  city            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  items    SaleItem[]
  invoices Invoice[]
  order    Order?

  @@map("sales")
}

model SaleItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  stockMovements StockMovement[]

  @@map("sale_items")
}

model StockMovement {
  id        String       @id @default(cuid())
  type      MovementType
  quantity  Int
  reason    String?
  createdAt DateTime     @default(now())

  productId  String
  product    Product   @relation(fields: [productId], references: [id])
  saleItemId String?
  saleItem   SaleItem? @relation(fields: [saleItemId], references: [id])
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])

  @@map("stock_movements")
}

model Setting {
  key       String   @id
  value     String   @db.Text
  label     String
  group     String
  hint      String?
  sensitive Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("settings")
}

enum BillingProvider {
  OPENFACTURA
  FACTO
  BSALE
  DEFONTANA
  NUBOX
  SIIGO
}

enum DteType {
  FACTURA
  BOLETA
  NOTA_CREDITO
  NOTA_DEBITO
  FACTURA_EXENTA
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  ACCEPTED
  REJECTED
  CANCELLED
}

model BillingConnection {
  id          String          @id @default(cuid())
  name        String
  provider    BillingProvider
  credentials Json?
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  invoices  Invoice[]

  @@map("billing_connections")
}

model Invoice {
  id          String        @id @default(cuid())
  folio       Int?
  dteType     DteType
  rut         String
  razonSocial String
  giro        String?
  address     String?
  commune     String?
  email       String?
  netAmount   Decimal       @db.Decimal(12, 2)
  tax         Decimal       @db.Decimal(12, 2)
  totalAmount Decimal       @db.Decimal(12, 2)
  items       Json
  notes       String?
  status      InvoiceStatus @default(DRAFT)
  pdfUrl      String?
  xmlUrl      String?
  externalId  String?
  issuedAt    DateTime?
  errorMsg    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  connectionId String
  connection   BillingConnection @relation(fields: [connectionId], references: [id])
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id])
  saleId       String?
  sale         Sale?             @relation(fields: [saleId], references: [id])

  @@map("invoices")
}

model PlatformSetting {
  id          String   @id @default(cuid())
  platform    String   @unique
  displayName String?
  description String?
  logoUrl     String?
  updatedAt   DateTime @updatedAt

  @@map("platform_settings")
}

model Order {
  id              String          @id @default(cuid())
  status          OrderStatus     @default(PENDING)
  fulfillmentType FulfillmentType @default(DELIVERY)
  notes           String?
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  address         String?
  commune         String?
  city            String?
  region          String?
  courier         String?
  trackingCode    String?
  scheduledDate   DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  saleId      String?    @unique
  sale        Sale?      @relation(fields: [saleId], references: [id])
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  createdById String?
  createdBy   User?      @relation("OrderCreatedBy", fields: [createdById], references: [id])

  itemChecks OrderItemCheck[]
  photos     ShipmentPhoto[]
  routeStop  RouteStop?

  @@map("orders")
}

model OrderItemCheck {
  id          String    @id @default(cuid())
  productName String
  productSku  String
  expectedQty Int
  checkedQty  Int?
  checked     Boolean   @default(false)
  notes       String?
  checkedAt   DateTime?

  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  checkedById String?
  checkedBy   User?    @relation("ItemCheckedBy", fields: [checkedById], references: [id])

  @@map("order_item_checks")
}

model ShipmentPhoto {
  id        String   @id @default(cuid())
  url       String
  filename  String
  notes     String?
  createdAt DateTime @default(now())

  orderId      String
  order        Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploadedById String?
  uploadedBy   User?  @relation(fields: [uploadedById], references: [id])

  @@map("shipment_photos")
}

model DispatchRoute {
  id          String      @id @default(cuid())
  name        String
  date        DateTime    @db.Date
  status      RouteStatus @default(PENDING)
  notes       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  companyId    String
  company      Company       @relation(fields: [companyId], references: [id])
  dispatcherId String?
  dispatcher   User?         @relation("DispatcherRoutes", fields: [dispatcherId], references: [id])
  createdById  String?
  createdBy    User?         @relation("RouteCreatedBy", fields: [createdById], references: [id])

  stops RouteStop[]

  @@map("dispatch_routes")
}

model RouteStop {
  id          String    @id @default(cuid())
  position    Int
  notes       String?
  lat         Float?
  lng         Float?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  routeId String
  route   DispatchRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  orderId String        @unique
  order   Order         @relation(fields: [orderId], references: [id])

  @@map("route_stops")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  changes   Json?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model EmailConfig {
  id        String   @id @default(cuid())
  companyId String   @unique
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  host      String
  port      Int      @default(587)
  secure    Boolean  @default(false)
  user      String
  pass      String
  fromName  String
  fromEmail String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_configs")
}

model EmailTemplate {
  id        String    @id @default(cuid())
  companyId String?
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type      EmailType
  subject   String
  bodyHtml  String    @db.Text
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([companyId, type])
  @@map("email_templates")
}
