generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  CATALOG_MANAGER
  VENDEDOR
}

enum MarketplaceType {
  MERCADO_LIBRE
  SHOPIFY
  WOOCOMMERCE
  JUMPSELLER
  FALABELLA
  PARIS
  HITES
  RIPLEY
  WALMART
}

enum ListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  ERROR
}

enum SaleChannel {
  POS
  MERCADO_LIBRE
  SHOPIFY
  WOOCOMMERCE
  JUMPSELLER
  FALABELLA
  PARIS
  HITES
  RIPLEY
  WALMART
  MANUAL
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum MovementType {
  SALE
  RETURN
  ADJUSTMENT
  INITIAL
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active          Boolean  @default(true)
  maxUsers        Int      @default(10)
  modules         Json?
  mlClientId      String?
  mlClientSecret  String?
  createdAt       DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  products           Product[]
  warehouses         Warehouse[]
  connections        MarketplaceConnection[]
  sales              Sale[]
  billingConnections BillingConnection[]
  invoices           Invoice[]

  @@map("companies")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  modules Json?

  auditLogs      AuditLog[]
  sales          Sale[]
  stockMovements StockMovement[]

  @@map("users")
}

model MarketplaceConnection {
  id             String          @id @default(cuid())
  name           String
  marketplace    MarketplaceType
  mlClientId     String?
  mlClientSecret String?
  accessToken    String          @default("")
  refreshToken   String?
  expiresAt      DateTime?
  credentials    Json?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  listings Listing[]

  @@map("marketplace_connections")
}

model Warehouse {
  id          String    @id @default(cuid())
  name        String
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  products Product[]

  @@map("warehouses")
}

model Product {
  id          String   @id @default(cuid())
  sku         String
  name        String
  description    String?  @db.Text
  mlDescription  String?  @db.Text
  mlAttributes   Json?
  price          Decimal  @db.Decimal(10, 2)
  cost           Decimal? @db.Decimal(10, 2)
  stock          Int      @default(0)
  mlCategoryId   String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  images         ProductImage[]
  listings       Listing[]
  saleItems      SaleItem[]
  stockMovements StockMovement[]

  @@unique([sku, companyId])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  filename  String
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Listing {
  id         String        @id @default(cuid())
  externalId String?
  status     ListingStatus @default(DRAFT)
  externalUrl String?
  syncedAt   DateTime?
  errorMsg   String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  productId    String
  product      Product               @relation(fields: [productId], references: [id])
  connectionId String
  connection   MarketplaceConnection @relation(fields: [connectionId], references: [id])

  @@unique([productId, connectionId])
  @@map("listings")
}

model Sale {
  id            String        @id @default(cuid())
  channel       SaleChannel   @default(POS)
  externalId    String?
  total         Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  items    SaleItem[]
  invoices Invoice[]

  @@map("sales")
}

model SaleItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  stockMovements StockMovement[]

  @@map("sale_items")
}

model StockMovement {
  id        String       @id @default(cuid())
  type      MovementType
  quantity  Int
  reason    String?
  createdAt DateTime     @default(now())

  productId  String
  product    Product   @relation(fields: [productId], references: [id])
  saleItemId String?
  saleItem   SaleItem? @relation(fields: [saleItemId], references: [id])
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])

  @@map("stock_movements")
}

model Setting {
  key       String   @id
  value     String   @db.Text
  label     String
  group     String
  hint      String?
  sensitive Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("settings")
}

enum BillingProvider {
  OPENFACTURA
  FACTO
  BSALE
  DEFONTANA
  NUBOX
  SIIGO
}

enum DteType {
  FACTURA
  BOLETA
  NOTA_CREDITO
  NOTA_DEBITO
  FACTURA_EXENTA
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  ACCEPTED
  REJECTED
  CANCELLED
}

model BillingConnection {
  id          String          @id @default(cuid())
  name        String
  provider    BillingProvider
  credentials Json?
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  invoices  Invoice[]

  @@map("billing_connections")
}

model Invoice {
  id          String        @id @default(cuid())
  folio       Int?
  dteType     DteType
  rut         String
  razonSocial String
  giro        String?
  address     String?
  commune     String?
  email       String?
  netAmount   Decimal       @db.Decimal(12, 2)
  tax         Decimal       @db.Decimal(12, 2)
  totalAmount Decimal       @db.Decimal(12, 2)
  items       Json
  notes       String?
  status      InvoiceStatus @default(DRAFT)
  pdfUrl      String?
  xmlUrl      String?
  externalId  String?
  issuedAt    DateTime?
  errorMsg    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  connectionId String
  connection   BillingConnection @relation(fields: [connectionId], references: [id])
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id])
  saleId       String?
  sale         Sale?             @relation(fields: [saleId], references: [id])

  @@map("invoices")
}

model PlatformSetting {
  id          String   @id @default(cuid())
  platform    String   @unique
  displayName String?
  description String?
  logoUrl     String?
  updatedAt   DateTime @updatedAt

  @@map("platform_settings")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  changes   Json?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
